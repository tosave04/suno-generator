# ===========================================
# Suno Generator — Variables d'environnement
# ===========================================
# Copier ce fichier en .env.local et remplir les valeurs

# Base de données SQLite (chemin relatif depuis la racine du projet)
DATABASE_URL="file:./prisma/dev.db"

# API DeepSeek — Clé d'API pour la génération IA
# Obtenir une clé : https://platform.deepseek.com/
DEEPSEEK_API_KEY=""

# Modèle DeepSeek à utiliser (optionnel, défaut: deepseek-chat)
# deepseek-chat = rapide, supporte system prompt + JSON (recommandé)
# deepseek-reasoner = plus lent, raisonnement avancé, limitations API
DEEPSEEK_MODEL="deepseek-chat"
